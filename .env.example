# Скопируйте этот файл в .env и заполните значения
# cp .env.example .env

# Секретный ключ Flask (используется для сессий и CSRF).
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret-key

# Строка подключения к БД.
# На Vercel относительные sqlite-пути автоматически заменяются на sqlite:///:memory:
# (файловая система /var/task доступна только на чтение).
# Локально относительные пути резолвятся относительно корня проекта.
#
# Локальная разработка (файл в корне проекта):
DATABASE_URL=sqlite:///bakery_new.db
# Абсолютный путь (тоже работает):
# DATABASE_URL=sqlite:///C:/Users/pegas/bakery_new.db
# PostgreSQL (рекомендуется для продакшена):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Режим отладки Flask (True только для локальной разработки!)
FLASK_DEBUG=True

# Логин/пароль администратора, создаваемого при первом запуске seed-скрипта
ADMIN_EMAIL=admin@bakery-demo.com
ADMIN_PASSWORD=admin12345